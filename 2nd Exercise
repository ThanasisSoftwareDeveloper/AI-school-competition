def detect_operator(op_tile):
    img = op_tile.squeeze().cpu()
    center = img[8:20, 8:20]
    vertical   = center[:, 4:8].mean().item()
    horizontal = center[4:8, :].mean().item()
    if horizontal < 0.05:
        return '+'
    ratio = vertical / (horizontal + 1e-6)
    return '+' if ratio > 0.35 else '-'

def predict(model, x):
    if x.dim() == 4:
        x = x.squeeze(0)  # (1, 28, 140)

    tiles = [x[:, :, i*28:(i+1)*28] for i in range(5)]

    model.eval()
    def pred_digit(tile):
        with torch.no_grad():
            return model(tile.unsqueeze(0).to(device)).argmax(1).item()

    A  = pred_digit(tiles[0])
    B  = pred_digit(tiles[1])
    op = detect_operator(tiles[2])   # η συνάρτηση από το final notebook
    C  = pred_digit(tiles[3])
    D  = pred_digit(tiles[4])
    AB = A * 10 + B
    CD = C * 10 + D
    result = AB + CD if op == '+' else AB - CD
    return f'{AB}{op}{CD}={result}'
