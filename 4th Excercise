import torch
import json

# Make sure you already have: movies, levels, embeddings από το βήμα 1

def optimize_embedding(E, target_order, n_steps=5000, lr=0.02, n_restarts=5):
    """
    Βρίσκει το βέλτιστο embedding με gradient descent + multiple restarts.
    """
    N, D = E.shape
    non_targets = [i for i in range(N) if i not in target_order.tolist()]
    non_targets_tensor = torch.tensor(non_targets)
    
    best_emb = None
    best_min_diff = -999.0
    best_correct = False
    
    for restart in range(n_restarts):
        # Διαφορετική αρχικοποίηση σε κάθε restart
        if restart == 0:
            # Restart 0: μέσος όρος targets
            emb_init = E[target_order].mean(0).clone()
        elif restart == 1:
            # Restart 1: weighted μέσος (πιο βάρος στις πρώτες)
            weights = torch.tensor([5.0, 4.0, 3.0, 2.0, 1.0])
            weights /= weights.sum()
            emb_init = (E[target_order] * weights.unsqueeze(1)).sum(0).clone()
        else:
            # Υπόλοιποι restarts: τυχαία διαταραχή γύρω από τον μέσο όρο
            emb_init = E[target_order].mean(0).clone() + torch.randn(D) * 0.1
        
        emb = emb_init.detach().requires_grad_(True)
        optimizer = torch.optim.Adam([emb], lr=lr)
        scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, n_steps)
        
        local_best_emb = (emb / emb.norm()).detach().clone()
        local_best_min_diff = -999.0
        local_best_correct = False
        
        for step in range(n_steps):
            optimizer.zero_grad()
            
            emb_norm = emb / emb.norm()
            sim = torch.cosine_similarity(E, emb_norm.unsqueeze(0))
            
            target_sims = sim[target_order]        # [5] - similarities στόχων
            non_target_sims = sim[non_targets_tensor]  # similarities υπολοίπων
            
            # Loss 1: Σωστή φθίνουσα σειρά στόχων
            order_loss = torch.relu(target_sims[1:] - target_sims[:-1] + 0.02).sum()
            
            # Loss 2: Ο τελευταίος στόχος να είναι ΠΑΝΩ από ΟΛΕΣ τις υπόλοιπες
            margin = 0.08
            margin_loss = torch.relu(non_target_sims - target_sims[-1] + margin).sum()
            
            # Loss 3: Μεγιστοποίηση gap μεταξύ 5ου στόχου και 6ης ταινίας
            top6_sim = sim.topk(6).values
            gap_bonus = -(top6_sim[4] - top6_sim[5])  # θέλουμε μεγάλο gap
            
            # Loss 4: Μεγιστοποίηση ελάχιστης διαφοράς μεταξύ διαδοχικών
            consec_diffs = target_sims[:-1] - target_sims[1:]  # [4] θετικές αν σωστή σειρά
            min_diff_loss = -consec_diffs.min()  # θέλουμε να μεγιστοποιήσουμε
            
            loss = (order_loss * 20 + 
                    margin_loss * 10 + 
                    gap_bonus * 5 + 
                    min_diff_loss * 3)
            
            loss.backward()
            optimizer.step()
            scheduler.step()
            
            # Αξιολόγηση κάθε 50 steps
            if step % 50 == 0:
                with torch.no_grad():
                    en = emb / emb.norm()
                    s = torch.cosine_similarity(E, en.unsqueeze(0))
                    rank = s.argsort(descending=True)
                    correct = torch.all(rank[:5] == target_order).item()
                    
                    if correct:
                        diffs = (s[target_order[:-1]] - s[target_order[1:]]).min().item()
                        gap_56 = (s[rank[4]] - s[rank[5]]).item()
                        total_min_diff = min(diffs, gap_56)
                        
                        if total_min_diff > local_best_min_diff:
                            local_best_min_diff = total_min_diff
                            local_best_emb = en.clone()
                            local_best_correct = True
        
        # Ενημέρωση global best
        if local_best_correct and local_best_min_diff > best_min_diff:
            best_min_diff = local_best_min_diff
            best_emb = local_best_emb.clone()
            best_correct = True
            print(f"  Restart {restart}: ✅ Νέο καλύτερο! min_diff={best_min_diff:.4f}")
        elif not best_correct:
            # Κράτα ό,τι έχουμε έστω κι αν δεν είναι σωστό
            best_emb = local_best_emb.clone()
            print(f"  Restart {restart}: ❌ Δεν βρέθηκε σωστή σειρά")
        else:
            print(f"  Restart {restart}: min_diff={local_best_min_diff:.4f} (δεν βελτίωσε)")
    
    return best_emb, best_correct, best_min_diff


def evaluate(emb, E, target_order, level, movies):
    """Εκτυπώνει αποτελέσματα για ένα level."""
    with torch.no_grad():
        emb_norm = emb / emb.norm()
        similarity = torch.cosine_similarity(E, emb_norm.unsqueeze(0))
        ranking = similarity.argsort(descending=True)
        
        print("  Top 6 ταινίες:")
        for i, idx in enumerate(ranking[:6]):
            title = movies[level[idx.item()]]['title']
            sim_val = similarity[idx].item()
            if i < 5:
                marker = "✅" if idx.item() == target_order[i].item() else "❌"
            else:
                marker = "  "
            print(f"    {i+1}. {marker} {title} (sim={sim_val:.4f})")
        
        correct = torch.all(ranking[:5] == target_order).item()
        diffs = -similarity[ranking].diff()[:5]
        print(f"  Σωστή σειρά: {'✅' if correct else '❌'}")
        print(f"  Διαφορές: {', '.join(f'{d:.4f}' for d in diffs)}")
        print(f"  Ελάχιστη διαφορά: {diffs.min():.4f}")
        return emb_norm


